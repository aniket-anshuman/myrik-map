{
  "version": 2,
  "buildCommand": "npm install",
  "functions": {
    "server.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/", "destination": "/index-tabbed.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
